{
  "name": "axia-3d",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-wasm.mjs",
    "dev": "vite",
    "build": "tsc && vite build --emptyOutDir false",
    "build:wasm": "npm run wasm:build && npm run wasm:verify",
    "build:all": "npm run build:wasm && npm run build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "wasm:build": "cd ../crates/axia-wasm && wasm-pack build --target web --out-dir ../../web/src/wasm",
    "wasm:build:nodejs": "cd ../crates/axia-wasm && wasm-pack build --target nodejs --out-dir ../../packages/axia-wasm-node/dist",
    "wasm:verify": "node scripts/verify-wasm.mjs && node scripts/verify-simd.mjs",
    "wasm:verify-simd": "node scripts/verify-simd.mjs"
  },
  "dependencies": {
    "@axia/action-catalog": "file:../packages/axia-action-catalog",
    "@mlightcad/libredwg-web": "^0.6.10",
    "dwgdxf": "^1.0.5",
    "dxf": "^5.3.1",
    "jszip": "^3.10.1",
    "opencascade.js": "^2.0.0-beta.b5ff984",
    "rhino3dm": "^8.17.0",
    "three": "^0.170.0",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
