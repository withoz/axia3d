# Dependencies
node_modules/
web/node_modules/

# Build outputs
dist/
build/
out/
target/
web/dist/

# ADR-124 — `web/src/build/` holds source-level guards for WASM build config
# (wasmSimdActivation.test.ts). Source directory, NOT a build-output dir;
# excluded from the `build/` pattern above.
!web/src/build/

# WASM artifacts (wasm-pack 산출물, 매번 재생성 가능 — LOCKED #40 follow-up).
# Was tracked previously; untracked here so binary cannot desync from
# `crates/axia-geo` / `crates/axia-wasm` source. `web/scripts/ensure-wasm.mjs`
# (postinstall hook) rebuilds these on dev clone; CI rebuilds explicitly.
web/src/wasm/axia_wasm.d.ts
web/src/wasm/axia_wasm.js
web/src/wasm/axia_wasm_bg.wasm
web/src/wasm/axia_wasm_bg.wasm.d.ts
web/src/wasm/*.wasm

# Node WASM target (ADR-041 — wasm-pack --target nodejs 산출물, 재빌드 가능)
packages/axia-wasm-node/dist/

# MCP server build artifacts (ADR-041)
packages/axia-mcp-server/dist/
packages/axia-mcp-server/node_modules/

# create-axia-mcp scaffold build artifacts (ADR-043)
packages/create-axia-mcp/dist/
packages/create-axia-mcp/node_modules/

# action catalog build artifacts (ADR-045 D1)
packages/axia-action-catalog/dist/
packages/axia-action-catalog/node_modules/

# Node
web/node_modules/

# Build output assets (재빌드 가능, 용량 큼)
web/dist/assets/*.js
web/dist/assets/*.wasm
web/dist/assets/*.css
*.wasm

# Backup folders (로컬 백업, GitHub에 불필요)
backup_*/
backups/

# Rust
Cargo.lock
**/*.rs.bk

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*

# Misc
*.tmp
*.bak
*.tar.gz

# Claude
.claudeignore
.claude/worktrees/